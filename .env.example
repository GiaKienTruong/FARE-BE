# FARE Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Database - PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fare_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Cloudinary - Image Storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_api_secret

# AI Service - Self-hosted CatVTON
AI_SERVICE_URL=http://localhost:7860

# Optional: Remove.bg API (for background removal)
REMOVEBG_API_KEY=your_removebg_api_key

# Optional: Replicate API (if using cloud AI instead of self-hosted)
# REPLICATE_API_TOKEN=r8_xxxx
